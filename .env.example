# =============================================================================
# Orbit Development Environment — Secret Variables
# =============================================================================
# Copy this file to .env and fill in real values before running `make dev`.
#   cp .env.example .env
#
# DEV-ONLY GENERATION HINTS:
#   Random 32-byte hex:  openssl rand -hex 32
#   Random 64-byte hex:  openssl rand -hex 64
#
# NEVER commit a real .env file. The .gitignore already excludes it.
# =============================================================================

# ----------------------------------------------------------------------------
# MinIO (object storage — used by registry and Pulumi state backend)
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=orbit-admin
# Replace with a strong password in any non-throwaway environment.
MINIO_ROOT_PASSWORD=<generate: openssl rand -hex 32>

# ----------------------------------------------------------------------------
# Container Registry
# ----------------------------------------------------------------------------
ORBIT_REGISTRY_PASSWORD=<generate: openssl rand -hex 32>

# ----------------------------------------------------------------------------
# Inter-service authentication
# ----------------------------------------------------------------------------
# Shared token between the Temporal worker, build service, and orbit-www.
ORBIT_INTERNAL_API_KEY=<generate: openssl rand -hex 32>

# Shared secret for the gRPC auth interceptor on kafka-service and
# repository-service. orbit-www mints bearer tokens signed with this value.
# Must be >= 32 bytes. Both Go services FAIL-FAST on startup if absent or too short.
# Also add this to orbit-www/.env (server-only — NOT prefixed NEXT_PUBLIC_).
ORBIT_SVC_AUTH_SECRET=<generate: openssl rand -base64 48>

# JWT secret for the Orbit container registry token endpoint.
ORBIT_REGISTRY_JWT_SECRET=<generate: openssl rand -hex 32>

# ----------------------------------------------------------------------------
# Pulumi (Azure launches worker)
# ----------------------------------------------------------------------------
# Passphrase used to encrypt Pulumi stack secrets at rest.
PULUMI_CONFIG_PASSPHRASE=<generate: openssl rand -hex 32>

# Azure service principal credentials (leave blank if not using Azure launches)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
